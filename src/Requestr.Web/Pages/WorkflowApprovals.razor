@page "/approvals"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using Requestr.Core.Models
@using Requestr.Core.Interfaces
@using Requestr.Core.Services.Workflow
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using BlazorBootstrap
@inject IFormRequestQueryService FormRequestQueryService
@inject IFormRequestApprovalService FormRequestApprovalService
@inject IWorkflowInstanceService WorkflowInstanceService
@inject IWorkflowExecutionService WorkflowExecutionService
@inject IWorkflowDefinitionQueryService WorkflowDefinitionQueryService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<WorkflowApprovals> Logger
@attribute [Authorize]

@inject Requestr.Web.Configuration.AppBrandingOptions Branding
@inject IUserTimezoneService Tz
<PageTitle>Workflow Approvals | @Branding.ApplicationName</PageTitle>

<PageHeader Title="Approvals" Description="Review and process form requests awaiting approval" />

<div class="container-fluid">

            <!-- Advanced Filters -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="bi bi-funnel me-2"></i>
                        Filters
                        <button class="btn btn-sm btn-link p-0 ms-2" @onclick="ToggleAdvancedFilters">
                            <i class="bi bi-@(_showAdvancedFilters ? "chevron-up" : "chevron-down")"></i>
                        </button>
                    </h6>
                </div>
                <div class="card-body @(_showAdvancedFilters ? "" : "d-none")">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Form</label>
                            <select class="form-select form-select-sm" @bind="SelectedFormFilter" @bind:after="ApplyFilters">
                                <option value="">All Forms</option>
                                @if (AllRequests?.Any() == true)
                                {
                                    @foreach (var form in AllRequests.Where(r => r.FormDefinition != null)
                                        .Select(r => r.FormDefinition!).DistinctBy(f => f.Id))
                                    {
                                        <option value="@form.Id">@form.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select class="form-select form-select-sm" @bind="SelectedStatusFilter" @bind:after="ApplyFilters">
                                <option value="">All Statuses</option>
                                <option value="Pending">Pending</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Completed">Completed</option>
                                <option value="Skipped">Skipped</option>
                                <option value="Failed">Failed</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sort Order</label>
                            <select class="form-select form-select-sm" @bind="SortOrder" @bind:after="ApplyFilters">
                                <option value="newest">Newest First</option>
                                <option value="oldest">Oldest First</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    @if (FilteredTasks.Any())
                                    {
                                        <text>Showing @FilteredTasks.Count of @AllTasks.Count approval tasks</text>
                                    }
                                    else if (AllTasks.Any())
                                    {
                                        <text>No tasks match your current filters (@AllTasks.Count total)</text>
                                    }
                                    else
                                    {
                                        <text>No approval tasks found</text>
                                    }
                                </small>
                                <button class="btn btn-sm btn-outline-primary" @onclick="RefreshData">
                                    <i class="bi bi-arrow-clockwise me-1"></i>
                                    Refresh
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <StandardAlert AlertType="success" 
                             Message="@SuccessMessage" />
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <StandardAlert AlertType="danger" 
                             Message="@ErrorMessage" />
            }

            <div class="card">
                <div class="card-body">
                    @if (IsLoading)
                    {
                        <LoadingSpinner Message="Loading approvals..." />
                    }
                    else if (!FilteredTasks.Any())
                    {
                        <EmptyState Title="No pending approvals" 
                                    Description="@GetEmptyStateDescription()" />
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="thead-themed">
                                    <tr>
                                        <th>ID</th>
                                        <th>Form</th>
                                        <th>Step</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Requested By</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in FilteredTasks)
                                    {
                                        <tr>
                                            <td>
                                                @if (task.Request.BulkFormRequestId.HasValue)
                                                {
                                                    <strong>Bulk #@task.Request.BulkFormRequestId</strong>
                                                }
                                                else
                                                {
                                                    <strong>#@task.Request.Id</strong>
                                                }
                                            </td>
                                            <td>@task.Request.FormDefinition?.Name</td>
                                            <td>@task.StepName</td>
                                            <td>
                                                <span class="badge bg-@(GetRequestTypeBadgeColor(task.Request.RequestType))">
                                                    @task.Request.RequestType
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(task.Request.Status)">@task.Request.Status</span>
                                            </td>
                                            <td>@task.Request.RequestedByName</td>
                                            <td>
                                                <small>@Tz.FormatDate(task.Request.RequestedAt)</small>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" 
                                                        @onclick="() => ViewApprovalTask(task)">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

@code {
    private record ApprovalTask(FormRequest Request, WorkflowStepInstance Step, string StepName);
    
    private List<FormRequest>? AllRequests;
    private List<ApprovalTask> AllTasks = new();
    private List<ApprovalTask> FilteredTasks = new();
    private bool IsLoading = true;
    private bool _showAdvancedFilters = true;
    private string SelectedFormFilter = "";
    private string SelectedStatusFilter = "InProgress";
    private string SortOrder = "newest";
    private string? SuccessMessage;
    private string? ErrorMessage;
    private ClaimsPrincipal? User;
    private List<string> UserRoles = new();

    private string GetEmptyStateDescription() => 
        string.IsNullOrEmpty(SelectedFormFilter) 
            ? "All approvals have been processed." 
            : "No requests match your current filters.";

    protected override async Task OnInitializedAsync()
    {
        await GetUserInfo();
        await LoadData();
    }

    private async Task GetUserInfo()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        
        if (User?.Identity?.IsAuthenticated == true)
        {
            UserRoles = User.Claims
                .Where(c => c.Type == "roles" || 
                           c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" ||
                           c.Type == ClaimTypes.Role)
                .Select(c => c.Value)
                .ToList();
        }
    }

    private async Task LoadData()
    {
        try
        {
            IsLoading = true;
            ClearMessages();

            if (User?.Identity?.IsAuthenticated == true)
            {
                var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
                
                // Log the user details and roles for debugging
                Logger.LogInformation("WorkflowApprovals: Loading data for user {UserName} (ID: {UserId})", User.Identity.Name, userId);
                Logger.LogInformation("WorkflowApprovals: User has {RoleCount} roles: {Roles}", UserRoles.Count, string.Join(", ", UserRoles));
                
                // Log all claims for debugging
                Logger.LogDebug("WorkflowApprovals: All user claims:");
                foreach (var claim in User.Claims)
                {
                    Logger.LogDebug("  {ClaimType}: {ClaimValue}", claim.Type, claim.Value);
                }

                AllRequests = await FormRequestQueryService.GetForWorkflowApprovalAsync(userId, UserRoles);
                
                Logger.LogInformation("WorkflowApprovals: Received {RequestCount} requests from service", AllRequests?.Count ?? 0);

                // Build flat list of approval tasks (one per active step per request)
                AllTasks.Clear();
                if (AllRequests?.Any() == true)
                {
                    Logger.LogInformation("WorkflowApprovals: Loading workflow steps for {RequestCount} requests", AllRequests.Count);
                    foreach (var request in AllRequests)
                    {
                        try
                        {
                            var currentSteps = await FormRequestApprovalService.GetCurrentWorkflowStepsAsync(request.Id);
                            if (currentSteps.Count > 0)
                            {
                                // Get workflow definition for step names
                                WorkflowDefinition? workflowDef = null;
                                if (request.WorkflowInstanceId.HasValue)
                                {
                                    var instance = await WorkflowInstanceService.GetWorkflowInstanceAsync(request.WorkflowInstanceId.Value);
                                    if (instance != null)
                                        workflowDef = await WorkflowDefinitionQueryService.GetWorkflowDefinitionAsync(instance.WorkflowDefinitionId);
                                }

                                foreach (var step in currentSteps)
                                {
                                    var stepDef = workflowDef?.Steps.FirstOrDefault(s => s.StepId == step.StepId);
                                    // Only include Approval steps
                                    if (stepDef?.StepType == WorkflowStepType.Approval || stepDef == null)
                                    {
                                        var stepName = stepDef?.Name ?? step.StepId;
                                        AllTasks.Add(new ApprovalTask(request, step, stepName));
                                        Logger.LogInformation("WorkflowApprovals: Request {RequestId} - Step: {StepId} ({StepName})", 
                                            request.Id, step.StepId, stepName);
                                    }
                                }
                            }
                            else
                            {
                                // Fallback: no active steps, still show the request
                                var singleStep = await FormRequestApprovalService.GetCurrentWorkflowStepAsync(request.Id);
                                AllTasks.Add(new ApprovalTask(request, singleStep!, singleStep?.StepId ?? "Unknown"));
                            }
                        }
                        catch (Exception ex)
                        {
                            Logger.LogError(ex, "Error loading workflow steps for request {RequestId}", request.Id);
                        }
                    }
                }

                Logger.LogInformation("WorkflowApprovals: Built {TaskCount} approval tasks from {RequestCount} requests", 
                    AllTasks.Count, AllRequests?.Count ?? 0);

                await ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading approvals: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private Task ApplyFilters()
    {
        var filtered = AllTasks.AsEnumerable();

        // Filter by form
        if (!string.IsNullOrEmpty(SelectedFormFilter) && int.TryParse(SelectedFormFilter, out var formId))
        {
            filtered = filtered.Where(t => t.Request.FormDefinitionId == formId);
        }

        // Filter by workflow step status
        if (!string.IsNullOrEmpty(SelectedStatusFilter))
        {
            filtered = filtered.Where(t => t.Step?.Status.ToString() == SelectedStatusFilter);
        }

        // Sort
        filtered = SortOrder switch
        {
            "oldest" => filtered.OrderBy(t => t.Request.RequestedAt),
            _ => filtered.OrderByDescending(t => t.Request.RequestedAt)
        };

        FilteredTasks = filtered.ToList();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ViewApprovalTask(ApprovalTask task)
    {
        try
        {
            var request = task.Request;
            
            if (request.WorkflowInstanceId.HasValue && task.Step != null)
            {
                var workflowUrl = $"/workflow/{request.WorkflowInstanceId}/step/{task.Step.StepId}";
                Logger.LogInformation("Navigating to approval step URL: {WorkflowUrl}", workflowUrl);
                Navigation.NavigateTo(workflowUrl);
            }
            else
            {
                var fallbackUrl = request.BulkFormRequestId.HasValue
                    ? $"/bulk-requests/{request.BulkFormRequestId}"
                    : $"/requests/{request.Id}";
                Logger.LogInformation("No workflow step, using fallback URL: {FallbackUrl}", fallbackUrl);
                Navigation.NavigateTo(fallbackUrl);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Exception in ViewApprovalTask for requestId: {RequestId}", task.Request.Id);
            Navigation.NavigateTo($"/requests/{task.Request.Id}");
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    private string GetRequestTypeBadgeColor(RequestType requestType) => UiHelper.GetRequestTypeColor(requestType);
    private string GetStatusBadgeClass(RequestStatus status) => UiHelper.GetStatusBadgeClass(status);

    private void ClearMessages()
    {
        SuccessMessage = null;
        ErrorMessage = null;
    }

    private void ToggleAdvancedFilters()
    {
        _showAdvancedFilters = !_showAdvancedFilters;
    }
}
