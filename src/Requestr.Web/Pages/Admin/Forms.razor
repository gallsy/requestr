@page "/admin/forms"
@using Requestr.Core.Models
@using Requestr.Core.Interfaces
@inject IFormDefinitionService FormDefinitionService
@inject IToastNotificationService toastService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Admin")]

@inject Requestr.Web.Configuration.AppBrandingOptions Branding
@inject IUserTimezoneService Tz
<PageTitle>Form Management | @Branding.ApplicationName Admin</PageTitle>

<PageHeader Title="Manage Forms" Description="Manage all forms including inactive ones">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick="CreateForm" title="Create New Form">
            <i class="bi bi-plus-lg"></i>
        </button>
    </Actions>
</PageHeader>

<div class="container-fluid">

    @if (_isLoading)
    {
        <LoadingSpinner Message="Loading forms..." />
    }
    else if (!_filteredForms.Any())
    {
        <EmptyState Title="No Forms Available" 
                    Description="@(StatusFilter == "active" ? "No active forms found" : StatusFilter == "inactive" ? "No inactive forms found" : "No forms found. Get started by creating your first form.")">
            <Action>
                <Button Color="ButtonColor.Primary" @onclick="CreateForm">
                    <Icon Name="IconName.Plus" class="me-2" />
                    Create New Form
                </Button>
            </Action>
        </EmptyState>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-center">
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" @bind="StatusFilter" @bind:after="ApplyFilter">
                            <option value="all">All Statuses</option>
                            <option value="active">Active Only</option>
                            <option value="inactive">Inactive Only</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" @bind="CategoryFilter" @bind:after="ApplyFilter">
                            <option value="">All Categories</option>
                            @foreach (var cat in _allCategories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" @bind="RoleFilter" @bind:after="ApplyFilter">
                            <option value="">All Roles</option>
                            @foreach (var role in _allRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 text-end">
                        <span class="text-muted small">@_filteredForms.Count of @(_forms?.Count ?? 0) forms</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Category</th>
                                <th>Roles</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var form in _filteredForms)
                            {
                                <tr>
                                    <td>
                                        <strong>@form.Name</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(form.Description))
                                        {
                                            <span title="@form.Description">
                                                @(form.Description.Length > 50 ? form.Description.Substring(0, 47) + "..." : form.Description)
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(form.Category))
                                        {
                                            <span class="badge bg-light text-dark border">@form.Category</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">&mdash;</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var roles = form.FormPermissions
                                                .Where(p => p.IsGranted)
                                                .Select(p => p.RoleName)
                                                .Distinct()
                                                .OrderBy(r => r)
                                                .ToList();
                                        }
                                        @if (roles.Any())
                                        {
                                            @foreach (var role in roles)
                                            {
                                                <span class="badge bg-secondary me-1 mb-1">@role</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No roles</span>
                                        }
                                    </td>
                                    <td>
                                        @if (form.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-outline-primary" @onclick="() => EditForm(form.Id)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-outline-info" @onclick="() => ViewForm(form.Id)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" @onclick="() => ToggleFormStatus(form)">
                                                <i class="bi @(form.IsActive ? "bi-pause-fill" : "bi-play-fill")"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteForm(form.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>                            </table>
                        </div>


                    </div>
                </div>
            }
</div>

@code {
    private List<FormDefinition> _forms = new();
    private List<FormDefinition> _filteredForms = new();
    private List<string> _allCategories = new();
    private List<string> _allRoles = new();
    private bool _isLoading = true;
    private string StatusFilter = "all";
    private string CategoryFilter = "";
    private string RoleFilter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadForms();
    }

    private async Task LoadForms()
    {
        try
        {
            _isLoading = true;
            _forms = await FormDefinitionService.GetFormDefinitionsAsync();
            _allCategories = _forms
                .Where(f => !string.IsNullOrEmpty(f.Category))
                .Select(f => f.Category)
                .Distinct()
                .OrderBy(c => c)
                .ToList();
            _allRoles = _forms
                .SelectMany(f => f.FormPermissions)
                .Where(p => p.IsGranted)
                .Select(p => p.RoleName)
                .Distinct()
                .OrderBy(r => r)
                .ToList();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error loading forms: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        var query = _forms.AsEnumerable();

        query = StatusFilter switch
        {
            "active" => query.Where(f => f.IsActive),
            "inactive" => query.Where(f => !f.IsActive),
            _ => query
        };

        if (!string.IsNullOrEmpty(CategoryFilter))
        {
            query = query.Where(f => string.Equals(f.Category, CategoryFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(RoleFilter))
        {
            query = query.Where(f => f.FormPermissions
                .Any(p => p.IsGranted && string.Equals(p.RoleName, RoleFilter, StringComparison.OrdinalIgnoreCase)));
        }

        _filteredForms = query.ToList();
    }

    private void CreateForm()
    {
        Navigation.NavigateTo("/admin/forms/builder");
    }

    private void EditForm(int formId)
    {
        Navigation.NavigateTo($"/admin/forms/builder/{formId}");
    }

    private void ViewForm(int formId)
    {
        Navigation.NavigateTo($"/forms/{formId}");
    }

    private async Task ToggleFormStatus(FormDefinition form)
    {
        try
        {
            form.IsActive = !form.IsActive;
            await FormDefinitionService.UpdateFormDefinitionAsync(form);
            ApplyFilter(); // Refresh the filtered list
            StateHasChanged();
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error updating form status: {ex.Message}");
            // Revert the change
            form.IsActive = !form.IsActive;
            ApplyFilter(); // Refresh the filtered list
        }
    }

    private async Task DeleteForm(int formId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this form? This action cannot be undone.");
        if (confirmed)
        {
            try
            {
                await FormDefinitionService.DeleteFormDefinitionAsync(formId);
                await LoadForms();
            }
            catch (Exception ex)
            {
                toastService.ShowError($"Error deleting form: {ex.Message}");
            }
        }
    }
}
