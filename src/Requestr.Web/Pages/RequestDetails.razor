@page "/requests/{RequestId:int}"
@using Requestr.Core.Models
@using Requestr.Core.Interfaces
@using Requestr.Core.Utilities
@using Requestr.Core.Services.Workflow
@using System.Text.Json
@using Requestr.Web.Components
@using Requestr.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorBootstrap
@inject IFormRequestQueryService FormRequestQueryService
@inject IFormRequestApprovalService FormRequestApprovalService
@inject IFormDefinitionService FormDefinitionService
@inject IConflictDetectionService ConflictDetectionService
@inject IWorkflowInstanceService WorkflowInstanceService
@inject IWorkflowProgressService WorkflowProgressService
@inject ILogger<RequestDetails> Logger
@inject NavigationManager Navigation
@inject IDatabaseService DatabaseService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUserTimezoneService Tz
@attribute [Authorize]

@if (_isLoading)
{
    <LoadingSpinner Message="Loading request details..." />
}
else if (_request == null)
{
    <EmptyState Title="Request Not Found" 
                Description="@(!string.IsNullOrEmpty(_errorMessage) ? _errorMessage : "The requested form request could not be found or you don't have permission to access it.")">
        <Action>
            <Button Color="ButtonColor.Primary" @onclick="@(() => Navigation.NavigateTo("/"))">
                Go Home
            </Button>
        </Action>
    </EmptyState>
}
else
{
    <PageHeader Title="@($"Request #{RequestId}")" 
                Description="@(_formDefinition?.Name ?? "Request Details")" />

    @if (!string.IsNullOrEmpty(_conflictWarning))
    {
        <StandardAlert AlertType="warning" 
                     Title="Data Conflicts Detected">
            <div style="white-space: pre-line;">@_conflictWarning</div>
        </StandardAlert>
    }

    @if (!string.IsNullOrEmpty(_retryMessage))
    {
        <StandardAlert AlertType="@(_retrySuccess ? "success" : "danger")"
                     Title="@(_retrySuccess ? "Retry Successful" : "Retry Failed")"
                     Dismissable="true">
            @_retryMessage
        </StandardAlert>
    }

    <div class="row g-4">
        <!-- Left column: Summary + Field Values -->
        <div class="col-12 col-xl-7 d-flex flex-column">
            <RequestSummaryCard 
                FormName="@(_formDefinition?.Name ?? "Unknown Form")"
                TableName="@_formDefinition?.TableName"
                RequestType="_request.RequestType"
                Status="_request.Status"
                Comments="@_request.Comments"
                RejectionReason="@_request.RejectionReason"
                FailureMessage="@_request.FailureMessage"
                SubmittedBy="@_request.RequestedByName"
                SubmittedAt="@_request.RequestedAt"
                ProcessedBy="@_request.ApprovedByName"
                ProcessedAt="@_request.ApprovedAt"
                HasWorkflow="@(_request.WorkflowInstanceId.HasValue)"
                ShowStatusExplainer="@(!_request.WorkflowInstanceId.HasValue)">
                <ActionButtons>
                    @if (_request.Status == RequestStatus.Failed && _isAdmin)
                    {
                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small" Disabled="_isRetrying"
                                @onclick="RetryFailedRequestAsync">
                            @if (_isRetrying)
                            {
                                <Spinner Size="SpinnerSize.Small" Class="me-1" />
                                <span>Retrying...</span>
                            }
                            else
                            {
                                <Icon Name="IconName.ArrowRepeat" class="me-1" />
                                <span>Retry</span>
                            }
                        </Button>
                    }
                    @if (_request.Status == RequestStatus.Pending && CanEditRequest())
                    {
                        <Button Color="ButtonColor.Primary" Size="ButtonSize.Small" Outline="true"
                                @onclick="@(() => Navigation.NavigateTo($"/forms/{_request.FormDefinitionId}/edit/{RequestId}"))">
                            <Icon Name="IconName.Pencil" class="me-1" />
                            Edit Request
                        </Button>
                    }
                </ActionButtons>
            </RequestSummaryCard>

            <RequestFieldValuesCard 
                FieldValues="@_request.FieldValues"
                OriginalValues="@_request.OriginalValues"
                FormFields="@_formDefinition?.Fields"
                RequestType="@_request.RequestType"
                Status="@_request.Status" />
        </div>

        <!-- Right column: Activity Timeline -->
        <div class="col-12 col-xl-5">
            <ActivityTimeline WorkflowProgress="@_workflowProgress"
                             Entries="@_unifiedTimeline" />
        </div>
    </div>
}

@code {
    [Parameter] public int RequestId { get; set; }
    
    private FormRequest? _request;
    private FormDefinition? _formDefinition;
    private List<FormRequestHistory> _requestHistory = new();
    private List<ColumnInfo> _tableColumns = new();
    private bool _isLoading = true;
    private string _conflictWarning = "";
    private string _errorMessage = "";
    private string _currentUserId = "";
    private List<string> _userRoles = new();
    private bool _isAdmin = false;
    private bool _isRetrying = false;
    private string? _retryMessage;
    private bool _retrySuccess;
    
    // Workflow-related fields
    private WorkflowStepInstance? _currentWorkflowStep;
    private List<WorkflowStepInstance>? _completedWorkflowSteps;
    private WorkflowProgress? _workflowProgress;
    
    // Unified timeline
    private List<ActivityTimeline.TimelineEntry> _unifiedTimeline = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRequest();
    }

    private async Task LoadRequest()
    {
        try
        {
            _isLoading = true;
            
            // Get current user info for security check
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                _errorMessage = "You must be logged in to view this page.";
                return;
            }
            
            _currentUserId = UserIdentityHelper.GetUserId(authState.User);
            _userRoles = ClaimsHelper.GetUserRoles(authState.User);
            _isAdmin = _userRoles.Contains("Admin");
            
            _request = await FormRequestQueryService.GetWithHistoryAsync(RequestId);
            
            if (_request == null)
            {
                _errorMessage = "Request not found.";
                return;
            }
            
            // Load form definition first (needed for security check)
            _formDefinition = await FormDefinitionService.GetByIdAsync(_request.FormDefinitionId);
            
            // Security check: User can view if they created it, are admin, or can approve it
            if (!await CanUserAccessRequestAsync())
            {
                Logger.LogWarning("User {UserId} attempted to access request {RequestId} without permission", 
                    _currentUserId, RequestId);
                _request = null; // Clear the request so it's not displayed
                _errorMessage = "You don't have permission to view this request.";
                return;
            }
            
            _requestHistory = _request.History;

            // Load column metadata for filtering on display
            try
            {
                if (_formDefinition != null)
                {
                    _tableColumns = await DatabaseService.GetTableColumnsAsync(
                        _formDefinition.DatabaseConnectionName,
                        _formDefinition.TableName,
                        _formDefinition.Schema
                    );
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load table columns for RequestDetails form {FormDefinitionId}", _request.FormDefinitionId);
                _tableColumns = new List<ColumnInfo>();
            }
            
            // Load workflow information if request has a workflow
            if (_request.WorkflowInstanceId.HasValue)
            {
                await LoadWorkflowInformation();
                await LoadWorkflowProgressAsync();
            }
            
            // Build the unified timeline from history + workflow data
            BuildUnifiedTimeline();

            // Check for conflicts only if the request is not in a terminal state
            var isCompleted = _request.Status == RequestStatus.Approved || 
                              _request.Status == RequestStatus.Rejected || 
                              _request.Status == RequestStatus.Applied || 
                              _request.Status == RequestStatus.Failed;
            if (!isCompleted && (_request.Status == RequestStatus.Pending || _request.WorkflowInstanceId.HasValue))
            {
                await CheckForConflictsAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading request {RequestId}", RequestId);
            _errorMessage = "Error loading request.";
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private bool CanUserAccessRequest()
    {
        if (_request == null) return false;
        
        // Admin can access any request
        if (_isAdmin) return true;
        
        // User can access if they created the request
        if (_request.RequestedBy == _currentUserId) return true;
        
        // User can access if they are an approver for this form (legacy role-based)
        if (_formDefinition?.ApproverRoles != null && _formDefinition.ApproverRoles.Any())
        {
            if (_userRoles.Any(ur => _formDefinition.ApproverRoles.Contains(ur, StringComparer.OrdinalIgnoreCase)))
            {
                return true;
            }
        }
        
        // For workflow-based requests, check is done asynchronously in CanUserAccessRequestAsync
        // This method just handles the synchronous checks
        return false;
    }
    
    private async Task<bool> CanUserAccessRequestAsync()
    {
        // First do synchronous checks
        if (CanUserAccessRequest()) return true;
        
        // User can access if the request has a workflow and user has participated in it
        // (either completed a step or is assigned to an approval step by role)
        if (_request?.WorkflowInstanceId.HasValue == true)
        {
            try
            {
                // Check if user has participated in this workflow (completed a step or is assigned)
                var hasParticipated = await WorkflowInstanceService.HasUserParticipatedInWorkflowAsync(
                    _currentUserId, _userRoles, _request.WorkflowInstanceId.Value);
                if (hasParticipated)
                {
                    return true;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error checking workflow access for request {RequestId}", RequestId);
            }
        }
        
        return false;
    }

    private IEnumerable<KeyValuePair<string, object?>> GetDisplayableFieldValues()
    {
        if (_request?.FieldValues == null)
            return Enumerable.Empty<KeyValuePair<string, object?>>();

        // For Insert requests, hide identity/computed/rowversion columns
        if (_request.RequestType == RequestType.Insert && _tableColumns != null && _tableColumns.Count > 0)
        {
            var autoCols = new HashSet<string>(_tableColumns
                .Where(c => c.IsIdentity || c.IsComputed || c.IsRowVersion)
                .Select(c => c.Name), StringComparer.OrdinalIgnoreCase);

            return _request.FieldValues.Where(kvp => !autoCols.Contains(kvp.Key));
        }

        return _request.FieldValues;
    }

    /// <summary>
    /// Compares two display values, handling datetime precision differences
    /// </summary>
    private bool AreDisplayValuesEqual(string? value1, string? value2)
    {
        if (value1 == value2) return true;
        if (string.IsNullOrEmpty(value1) && string.IsNullOrEmpty(value2)) return true;
        if (string.IsNullOrEmpty(value1) || string.IsNullOrEmpty(value2)) return false;

        // First try exact match (case-insensitive, trimmed)
        if (string.Equals(value1?.Trim(), value2?.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        // Only use datetime comparison if BOTH values look like datetimes (contain date separators and time components)
        var looksLikeDateTime1 = (value1!.Contains("-") || value1.Contains("/")) && 
                                  (value1.Contains(":") || value1.Contains("T"));
        var looksLikeDateTime2 = (value2!.Contains("-") || value2.Contains("/")) && 
                                  (value2.Contains(":") || value2.Contains("T"));
        
        if (looksLikeDateTime1 && looksLikeDateTime2 &&
            DateTime.TryParse(value1, System.Globalization.CultureInfo.InvariantCulture, 
                System.Globalization.DateTimeStyles.None, out var dt1) &&
            DateTime.TryParse(value2, System.Globalization.CultureInfo.InvariantCulture, 
                System.Globalization.DateTimeStyles.None, out var dt2))
        {
            // Compare with 1 second tolerance for precision differences
            return Math.Abs((dt1 - dt2).TotalSeconds) < 1;
        }

        // Values are different
        return false;
    }

    private async Task LoadWorkflowInformation()
    {
        try
        {
            if (_request != null)
            {
                _currentWorkflowStep = await FormRequestApprovalService.GetCurrentWorkflowStepAsync(_request.Id);
                _completedWorkflowSteps = await FormRequestApprovalService.GetCompletedWorkflowStepsAsync(_request.Id);
            }
        }
        catch (Exception)
        {
            // Log error - workflow information will remain null
        }
    }

    private async Task CheckForConflictsAsync()
    {
        try
        {
            if (_request?.Id > 0)
            {
                var conflictResult = await ConflictDetectionService.CheckForConflictsAsync(_request.Id);
                if (conflictResult.HasConflicts)
                {
                    _conflictWarning = string.Join("\n", conflictResult.ConflictMessages);
                }
            }
        }
        catch (Exception ex)
        {
            // Log the error but don't show it to the user since conflict detection is supplementary
            Logger.LogWarning(ex, "Conflict detection error for RequestId {RequestId}", RequestId);
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/requests");
    }

    private bool CanEditRequest()
    {
        // Users can edit their own pending requests
        return _request?.Status == RequestStatus.Pending;
    }

    private async Task RetryFailedRequestAsync()
    {
        if (_request == null || _isRetrying) return;

        _isRetrying = true;
        _retryMessage = null;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? _currentUserId;

            var success = await FormRequestApprovalService.RetryFailedAsync(
                _request.Id, _currentUserId, userName);

            if (success)
            {
                _retrySuccess = true;
                _retryMessage = "Request was successfully retried and applied to the database.";
            }
            else
            {
                _retrySuccess = false;
                _retryMessage = "Retry attempt failed. Check the request history below for details.";
            }

            // Reload the request to reflect the new status and history
            await LoadRequest();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error retrying request {RequestId}", RequestId);
            _retrySuccess = false;
            _retryMessage = $"An error occurred while retrying: {ex.Message}";
        }
        finally
        {
            _isRetrying = false;
        }
    }

    private string GetStatusBadgeColor(RequestStatus status) => UiHelper.GetStatusBadgeClass(status);
    private string GetRequestTypeBadgeColor(RequestType requestType) => UiHelper.GetRequestTypeBadgeClass(requestType);

    private string GetRequestTypeDisplayName(RequestType requestType) => requestType switch
    {
        RequestType.Insert => "Add New Record",
        RequestType.Update => "Update Record", 
        RequestType.Delete => "Delete Record",
        _ => requestType.ToString()
    };



    private string GetFieldDisplayName(string fieldName)
    {
        if (fieldName.StartsWith("Original_"))
        {
            var actualFieldName = fieldName.Substring(9);
            var field = _formDefinition?.Fields?.FirstOrDefault(f => f.Name == actualFieldName);
            return field?.DisplayName ?? actualFieldName;
        }

        var formField = _formDefinition?.Fields?.FirstOrDefault(f => f.Name == fieldName);
        return formField?.DisplayName ?? fieldName;
    }



    // ==========================================
    // Workflow Progress
    // ==========================================

    private async Task LoadWorkflowProgressAsync()
    {
        try
        {
            _workflowProgress = await WorkflowProgressService.GetWorkflowProgressAsync(RequestId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load workflow progress for RequestId {RequestId}", RequestId);
        }
    }

    // ==========================================
    // Unified Timeline Builder
    // ==========================================

    private void BuildUnifiedTimeline()
    {
        var entries = new List<ActivityTimeline.TimelineEntry>();
        var seenKeys = new HashSet<string>();

        // 1. Add workflow step entries (richer data: duration, roles)
        if (_workflowProgress != null)
        {
            foreach (var e in ActivityTimeline.BuildWorkflowStepEntries(_workflowProgress))
            {
                if (seenKeys.Add(e.DeduplicationKey))
                    entries.Add(e);
            }
        }

        // 2. Add request history entries, skipping workflow-specific ones that duplicate step data
        if (_requestHistory != null)
        {
            foreach (var h in _requestHistory)
            {
                if (_workflowProgress != null && ActivityTimeline.IsWorkflowHistoryType(h.ChangeType))
                    continue;

                var key = $"history-{h.ChangeType}-{h.ChangedAt.Ticks}";
                if (!seenKeys.Add(key)) continue;

                object? fieldChanges = null;
                if (h.ChangeType == FormRequestChangeType.Updated && h.NewValues.ContainsKey("FieldChanges"))
                {
                    fieldChanges = h.NewValues["FieldChanges"];
                }

                entries.Add(new ActivityTimeline.TimelineEntry
                {
                    Timestamp = h.ChangedAt,
                    Title = ActivityTimeline.GetHistoryTitle(h.ChangeType),
                    Icon = ActivityTimeline.GetHistoryIcon(h.ChangeType),
                    MarkerColor = ActivityTimeline.GetHistoryMarkerColor(h.ChangeType),
                    ActorName = h.ChangedByName,
                    Comments = h.Comments,
                    FieldChangesJson = fieldChanges,
                    SortPriority = ActivityTimeline.GetHistorySortPriority(h.ChangeType),
                    DeduplicationKey = key
                });
            }
        }

        _unifiedTimeline = ActivityTimeline.SortEntries(entries);
    }
}
