@page "/forms"
@using Requestr.Core.Models
@using Requestr.Web.Authorization
@attribute [Authorize]
@inject IFormDefinitionService FormDefinitionService
@inject IFormAuthorizationService FormAuthorizationService
@inject ILogger<NewRequest> Logger
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime

@inject Requestr.Web.Configuration.AppBrandingOptions Branding
<PageTitle>Create New Request | @Branding.ApplicationName</PageTitle>

<PageHeader Title="New Request" 
            Description="Choose a form below to submit a new request." />

@if (_isLoading || !_viewPreferenceLoaded)
{
    <LoadingSpinner />
}
else if (_forms == null || !_forms.Any())
{
    <EmptyState Title="No Forms Available" 
                Description="There are no active forms available for you to submit.">
        <Action>
            <Button Color="ButtonColor.Primary" @onclick="@(() => NavigationManager.NavigateTo("/"))">
                <Icon Name="IconName.House" class="me-2" />
                Return Home
            </Button>
        </Action>
    </EmptyState>
}
else
{
    @* --- Filter bar --- *@
    <div class="filter-bar mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search forms..." 
                           @bind="_searchText" @bind:event="oninput" @onkeyup="ApplyFilters" />
                    @if (!string.IsNullOrEmpty(_searchText))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    }
                </div>
            </div>
            @if (_categories.Count > 0)
            {
                <div class="col-12 col-md-auto">
                    <select class="form-select" @onchange="OnCategoryChanged">
                        <option value="">All Categories</option>
                        @foreach (var category in _categories.OrderBy(c => c))
                        {
                            <option value="@category" selected="@(_selectedCategory == category)">@category</option>
                        }
                    </select>
                </div>
            }
            <div class="col-auto d-flex align-items-center gap-2">
                <span class="text-muted small">@_filteredForms.Count form@(_filteredForms.Count != 1 ? "s" : "")</span>
                <div class="btn-group btn-group-sm" role="group" aria-label="View toggle">
                    <button type="button" class="btn @(_viewMode == ViewMode.Card ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick="() => SetViewMode(ViewMode.Card)" title="Card view">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                    </button>
                    <button type="button" class="btn @(_viewMode == ViewMode.List ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick="() => SetViewMode(ViewMode.List)" title="List view">
                        <i class="bi bi-list-ul"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!_filteredForms.Any())
    {
        <EmptyState Title="No Matching Forms" 
                    Description="No forms match your current filters. Try adjusting your search or category.">
            <Action>
                <Button Color="ButtonColor.Secondary" @onclick="ClearAllFilters">
                    <Icon Name="IconName.XCircle" class="me-2" />
                    Clear Filters
                </Button>
            </Action>
        </EmptyState>
    }
    else if (_viewMode == ViewMode.Card)
    {
        @* --- Card view --- *@
        @foreach (var categoryGroup in _displayGroupedForms)
        {
            var category = categoryGroup.Key;
            var forms = categoryGroup.Value;

            <div class="category-section mb-5">
                @if (_displayGroupedForms.Count > 1 || !string.IsNullOrEmpty(category))
                {
                    <div class="category-header">
                        <h3 class="category-title">@(string.IsNullOrEmpty(category) ? "Uncategorized" : category)</h3>
                        <div class="category-line"></div>
                    </div>
                }

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var form in forms)
                    {
                        <div class="col">
                            <div class="card h-100 form-card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">@form.Name</h5>
                                </div>
                                <div class="card-body">
                                    @if (!string.IsNullOrEmpty(form.Description))
                                    {
                                        <p class="card-text">@form.Description</p>
                                    }

                                    <div class="form-details">
                                        <div class="form-detail-item">
                                            <i class="bi bi-table me-2"></i>
                                            <span>@form.TableName</span>
                                        </div>
                                        <div class="form-detail-item">
                                            <i class="bi bi-card-checklist me-2"></i>
                                            <span>@form.Fields.Count fields</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer">
                                    <FormActionButtons Form="form" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        @* --- List / table view --- *@
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th class="d-none d-md-table-cell">Category</th>
                        <th class="d-none d-md-table-cell">Table</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var form in _filteredForms)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@form.Name</div>
                                @if (!string.IsNullOrEmpty(form.Description))
                                {
                                    <small class="text-muted d-block text-truncate" style="max-width: 350px;">@form.Description</small>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (!string.IsNullOrEmpty(form.Category))
                                {
                                    <span class="badge bg-light text-dark border">@form.Category</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell text-muted small">@form.TableName</td>
                            <td class="text-end">
                                <FormActionButtons Form="form" Compact="true" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<FormDefinition>? _forms;
    private List<FormDefinition> _filteredForms = new();
    private Dictionary<string, List<FormDefinition>> _displayGroupedForms = new();
    private bool _isLoading = true;
    private bool _viewPreferenceLoaded = false;
    private string? _selectedCategory;
    private string _searchText = string.Empty;
    private HashSet<string> _categories = new();
    private ViewMode _viewMode = ViewMode.Card;

    private enum ViewMode { Card, List }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "requestr-forms-view");
                if (Enum.TryParse<ViewMode>(stored, out var mode))
                {
                    _viewMode = mode;
                }
            }
            catch { }
            finally
            {
                _viewPreferenceLoaded = true;
                StateHasChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            var allForms = await FormDefinitionService.GetActiveAsync();

            _forms = new List<FormDefinition>();

            if (allForms != null)
            {
                foreach (var form in allForms)
                {
                    var hasAnyPermission = await FormAuthorizationService.UserHasAnyPermissionAsync(user, form.Id,
                        FormPermissionType.CreateRequest,
                        FormPermissionType.UpdateRequest,
                        FormPermissionType.ViewData,
                        FormPermissionType.BulkUploadCsv,
                        FormPermissionType.BulkActions);

                    if (hasAnyPermission)
                    {
                        _forms.Add(form);
                    }
                }
            }

            // Extract categories
            if (_forms != null)
            {
                foreach (var form in _forms)
                {
                    var category = string.IsNullOrWhiteSpace(form.Category) ? "" : form.Category.Trim();
                    if (!string.IsNullOrEmpty(category))
                    {
                        _categories.Add(category);
                    }
                }
            }

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading forms");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        if (_forms == null) return;

        var filtered = _forms.AsEnumerable();

        // Category filter
        if (!string.IsNullOrEmpty(_selectedCategory))
        {
            filtered = filtered.Where(f =>
                !string.IsNullOrWhiteSpace(f.Category) && f.Category.Trim() == _selectedCategory);
        }

        // Text search
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.Trim();
            filtered = filtered.Where(f =>
                f.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrEmpty(f.Category) && f.Category.Contains(search, StringComparison.OrdinalIgnoreCase)));
        }

        _filteredForms = filtered.ToList();

        // Rebuild grouped forms for card view
        _displayGroupedForms.Clear();
        foreach (var form in _filteredForms)
        {
            var category = string.IsNullOrWhiteSpace(form.Category) ? "" : form.Category.Trim();
            if (!_displayGroupedForms.ContainsKey(category))
            {
                _displayGroupedForms[category] = new List<FormDefinition>();
            }
            _displayGroupedForms[category].Add(form);
        }

        StateHasChanged();
    }

    private void OnCategoryChanged(ChangeEventArgs e)
    {
        _selectedCategory = e.Value?.ToString();
        if (string.IsNullOrEmpty(_selectedCategory)) _selectedCategory = null;
        ApplyFilters();
    }

    private void ClearSearch()
    {
        _searchText = string.Empty;
        ApplyFilters();
    }

    private void ClearAllFilters()
    {
        _searchText = string.Empty;
        _selectedCategory = null;
        ApplyFilters();
    }

    private async Task SetViewMode(ViewMode mode)
    {
        _viewMode = mode;
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "requestr-forms-view", mode.ToString());
        }
        catch { }
    }
}

<style>
    .filter-bar {
        padding: 1rem;
        background-color: var(--card-bg, var(--bs-body-bg));
        border: 1px solid var(--border-color);
        border-radius: var(--border-radius);
    }

    .form-card {
        border-radius: var(--border-radius);
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    .form-details {
        margin-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-detail-item {
        display: flex;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .category-header {
        display: flex;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .category-title {
        margin-bottom: 0;
        margin-right: 1rem;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--primary);
    }

    .category-line {
        flex-grow: 1;
        height: 1px;
        background-color: var(--border-color);
    }
</style>
