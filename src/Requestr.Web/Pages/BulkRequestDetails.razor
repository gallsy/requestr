@page "/bulk-requests/{BulkRequestId:int}"
@using Requestr.Core.Models
@using Requestr.Core.Interfaces
@using Requestr.Core.Utilities
@using Requestr.Core.Services.Workflow
@using Requestr.Web.Components.Shared
@using System.Linq
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorBootstrap
@inject IBulkFormRequestService BulkFormRequestService
@inject IConflictDetectionService ConflictDetectionService
@inject IWorkflowInstanceService WorkflowInstanceService
@inject IWorkflowProgressService WorkflowProgressService
@inject ILogger<BulkRequestDetails> Logger
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUserTimezoneService Tz
@attribute [Authorize]

@if (_isLoading)
{
    <LoadingSpinner Message="Loading bulk request..." />
}
else if (_bulkRequest == null)
{
    <EmptyState Title="Bulk Request Not Found" 
                Description="The requested bulk request could not be found or you don't have permission to access it.">
        <Action>
            <Button Color="ButtonColor.Primary" @onclick="@(() => Navigation.NavigateTo("/requests"))">
                Back to My Requests
            </Button>
        </Action>
    </EmptyState>
}
else
{
    <PageHeader Title="@($"Bulk Request #{BulkRequestId}")" 
                Description="@(_bulkRequest.FormDefinition?.Name ?? "Bulk Request Details")" />

    @if (!string.IsNullOrEmpty(_conflictWarning))
    {
        <StandardAlert AlertType="warning" 
                     Title="Data Conflicts Detected">
            <div style="white-space: pre-line;">@_conflictWarning</div>
        </StandardAlert>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <StandardAlert AlertType="danger" 
                     Message="@_errorMessage" />
    }

    <div class="row g-4">
        <!-- Left column: Summary + Individual Items -->
        <div class="col-12 col-xl-7 d-flex flex-column">
            <BulkSummaryCard FormName="@(_bulkRequest.FormDefinition?.Name ?? "Unknown Form")"
                             TableName="@(_bulkRequest.FormDefinition?.TableName ?? "")"
                             RequestType="@_bulkRequest.RequestType"
                             Status="@_bulkRequest.Status"
                             TotalRows="@_bulkRequest.TotalRows"
                             Comments="@_bulkRequest.Comments"
                             RejectionReason="@_bulkRequest.RejectionReason"
                             ProcessingSummary="@_bulkRequest.ProcessingSummary"
                             SubmittedBy="@_bulkRequest.RequestedByName"
                             SubmittedAt="@_bulkRequest.RequestedAt"
                             ProcessedBy="@_bulkRequest.ApprovedByName"
                             ProcessedAt="@_bulkRequest.ApprovedAt" />

            <!-- Individual Items -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Individual Items (@_bulkRequest.Items.Count)
                    </h5>
                    @if (_bulkRequest.Items.Count > 0)
                    {
                        <Button Color="ButtonColor.Link" Size="ButtonSize.Small" @onclick="ToggleAllRows">
                            @if (_expandedRows.Count == _bulkRequest.Items.Count)
                            {
                                <span>Collapse All</span>
                            }
                            else
                            {
                                <span>Expand All</span>
                            }
                        </Button>
                    }
                </div>
                <div class="card-body">
                    @if (_bulkRequest.Items.Any())
                    {
                        <div class="bulk-items-list">
                            @foreach (var item in _bulkRequest.Items.OrderBy(i => i.RowNumber))
                            {
                                var isExpanded = _expandedRows.Contains(item.RowNumber);
                                var keyFields = GetKeyFields(item);
                                
                                <div class="bulk-item-row @(isExpanded ? "expanded" : "") mb-2">
                                    <div class="bulk-item-header p-3 rounded @GetItemBackgroundClass(item.Status)" 
                                         @onclick="@(() => ToggleRow(item.RowNumber))"
                                         style="cursor: pointer;">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center gap-3">
                                                <span class="text-muted fw-bold">Row @item.RowNumber</span>
                                                <span class="badge @GetStatusBadgeClass(item.Status)">
                                                    @item.Status
                                                </span>
                                                @if (!string.IsNullOrEmpty(keyFields))
                                                {
                                                    <span class="key-fields text-muted">@keyFields</span>
                                                }
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="field-count text-muted small">
                                                    @item.FieldValues.Count field(s)
                                                </span>
                                                <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    @if (isExpanded)
                                    {
                                        <div class="bulk-item-details border border-top-0 rounded-bottom">
                                            <RequestFieldValuesCard 
                                                FieldValues="@item.FieldValues"
                                                OriginalValues="@item.OriginalValues"
                                                FormFields="@_bulkRequest.FormDefinition?.Fields"
                                                RequestType="@_bulkRequest.RequestType"
                                                ProcessingResult="@item.ProcessingResult"
                                                Status="@item.Status"
                                                ShowHeader="false"
                                                Compact="true" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-4">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-2">No individual items found.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right column: Activity Timeline -->
        <div class="col-12 col-xl-5">
            <ActivityTimeline WorkflowProgress="@_workflowProgress"
                             Entries="@_unifiedTimeline" />
        </div>
    </div>
}

@code {
    [Parameter] public int BulkRequestId { get; set; }
    [Parameter]
    [SupplyParameterFromQuery]
    public bool IsFromApprovals { get; set; }

    private BulkFormRequest? _bulkRequest;
    private bool _isLoading = true;
    private bool _isFromApprovals;
    private string _errorMessage = "";
#pragma warning disable CS0414 // Assigned but never read — reserved for future success notification UI
    private string _successMessage = "";
#pragma warning restore CS0414
    private string _conflictWarning = "";
    private HashSet<int> _expandedRows = new();
    private string _currentUserId = "";
    private List<string> _userRoles = new();
    private bool _isAdmin = false;
    
    // Workflow + timeline
    private WorkflowProgress? _workflowProgress;
    private List<ActivityTimeline.TimelineEntry> _unifiedTimeline = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            _isFromApprovals = IsFromApprovals;
            
            // Get current user info for security check
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                _errorMessage = "You must be logged in to view this page.";
                return;
            }
            
            _currentUserId = UserIdentityHelper.GetUserId(authState.User);
            _userRoles = ClaimsHelper.GetUserRoles(authState.User);
            _isAdmin = _userRoles.Contains("Admin");
            
            // Load the bulk request
            _bulkRequest = await BulkFormRequestService.GetBulkFormRequestByIdAsync(BulkRequestId);
            
            if (_bulkRequest == null)
            {
                _errorMessage = "Bulk request not found.";
                return;
            }
            
            // Security check: User can view if they created it, are admin, or can approve it
            if (!await CanUserAccessBulkRequestAsync())
            {
                Logger.LogWarning("User {UserId} attempted to access bulk request {BulkRequestId} without permission", 
                    _currentUserId, BulkRequestId);
                _bulkRequest = null;
                _errorMessage = "You don't have permission to view this bulk request.";
                return;
            }

            // Load workflow progress if applicable
            if (_bulkRequest.WorkflowInstanceId.HasValue && _bulkRequest.WorkflowFormRequestId.HasValue)
            {
                await LoadWorkflowProgressAsync();
            }

            // Build the unified timeline
            BuildUnifiedTimeline();

            // Check for conflicts only if the request is not in a terminal state
            var isCompleted = _bulkRequest.Status == RequestStatus.Approved || 
                              _bulkRequest.Status == RequestStatus.Rejected || 
                              _bulkRequest.Status == RequestStatus.Applied || 
                              _bulkRequest.Status == RequestStatus.Failed;
            if (!isCompleted && (_bulkRequest.Status == RequestStatus.Pending || _bulkRequest.WorkflowFormRequestId.HasValue))
            {
                await CheckForConflictsAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading bulk request {BulkRequestId}", BulkRequestId);
            _errorMessage = "An unexpected error occurred while loading the bulk request. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    // ==========================================
    // Workflow Progress
    // ==========================================

    private async Task LoadWorkflowProgressAsync()
    {
        try
        {
            if (_bulkRequest?.WorkflowFormRequestId.HasValue == true)
            {
                _workflowProgress = await WorkflowProgressService.GetWorkflowProgressAsync(
                    _bulkRequest.WorkflowFormRequestId.Value);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load workflow progress for BulkRequestId {BulkRequestId}", BulkRequestId);
        }
    }

    // ==========================================
    // Unified Timeline Builder
    // ==========================================

    private void BuildUnifiedTimeline()
    {
        var entries = new List<ActivityTimeline.TimelineEntry>();
        var seenKeys = new HashSet<string>();

        // 1. Add workflow step entries
        if (_workflowProgress != null)
        {
            foreach (var e in ActivityTimeline.BuildWorkflowStepEntries(_workflowProgress))
            {
                if (seenKeys.Add(e.DeduplicationKey))
                    entries.Add(e);
            }
        }

        // 2. Add bulk request history entries
        if (_bulkRequest?.History != null)
        {
            foreach (var h in _bulkRequest.History)
            {
                if (_workflowProgress != null && ActivityTimeline.IsWorkflowHistoryType(h.ChangeType))
                    continue;

                var key = $"history-{h.ChangeType}-{h.ChangedAt.Ticks}";
                if (!seenKeys.Add(key)) continue;

                entries.Add(new ActivityTimeline.TimelineEntry
                {
                    Timestamp = h.ChangedAt,
                    Title = ActivityTimeline.GetHistoryTitle(h.ChangeType),
                    Icon = ActivityTimeline.GetHistoryIcon(h.ChangeType),
                    MarkerColor = ActivityTimeline.GetHistoryMarkerColor(h.ChangeType),
                    ActorName = h.ChangedByName,
                    Comments = h.Comments,
                    SortPriority = ActivityTimeline.GetHistorySortPriority(h.ChangeType),
                    DeduplicationKey = key
                });
            }
        }

        _unifiedTimeline = ActivityTimeline.SortEntries(entries);
    }

    // ==========================================
    // Access Control
    // ==========================================

    private bool CanUserAccessBulkRequest()
    {
        if (_bulkRequest == null) return false;
        if (_isAdmin) return true;
        if (_bulkRequest.RequestedBy == _currentUserId) return true;
        
        if (_bulkRequest.FormDefinition?.ApproverRoles != null && _bulkRequest.FormDefinition.ApproverRoles.Any())
        {
            if (_userRoles.Any(ur => _bulkRequest.FormDefinition.ApproverRoles.Contains(ur, StringComparer.OrdinalIgnoreCase)))
                return true;
        }
        
        return false;
    }
    
    private async Task<bool> CanUserAccessBulkRequestAsync()
    {
        if (CanUserAccessBulkRequest()) return true;
        
        if (_bulkRequest?.WorkflowInstanceId.HasValue == true)
        {
            try
            {
                var hasParticipated = await WorkflowInstanceService.HasUserParticipatedInWorkflowAsync(
                    _currentUserId, _userRoles, _bulkRequest.WorkflowInstanceId.Value);
                if (hasParticipated) return true;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error checking workflow access for bulk request {BulkRequestId}", BulkRequestId);
            }
        }
        
        return false;
    }

    private async Task CheckForConflictsAsync()
    {
        try
        {
            if (_bulkRequest?.Id > 0)
            {
                var conflictResult = await ConflictDetectionService.CheckBulkRequestConflictsAsync(_bulkRequest.Id);
                if (conflictResult.HasConflicts)
                {
                    _conflictWarning = string.Join("\n", conflictResult.ConflictMessages);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Conflict detection error for BulkRequestId {BulkRequestId}", BulkRequestId);
        }
    }

    // ==========================================
    // Item List Helpers
    // ==========================================

    private void ToggleRow(int rowNumber)
    {
        if (_expandedRows.Contains(rowNumber))
            _expandedRows.Remove(rowNumber);
        else
            _expandedRows.Add(rowNumber);
    }

    private void ToggleAllRows()
    {
        if (_bulkRequest == null) return;
        
        if (_expandedRows.Count == _bulkRequest.Items.Count)
            _expandedRows.Clear();
        else
            _expandedRows = _bulkRequest.Items.Select(i => i.RowNumber).ToHashSet();
    }

    private string GetKeyFields(BulkFormRequestItem item)
    {
        var preview = item.FieldValues.Take(3).Select(f => $"{f.Key}: {TruncateValue(f.Value?.ToString())}");
        return string.Join(" | ", preview);
    }

    private string TruncateValue(string? value, int maxLength = 20)
    {
        if (string.IsNullOrEmpty(value)) return "(empty)";
        return value.Length > maxLength ? value.Substring(0, maxLength) + "..." : value;
    }

    private string GetItemBackgroundClass(RequestStatus status) => status switch
    {
        RequestStatus.Approved => "bg-success bg-opacity-10",
        RequestStatus.Applied => "bg-primary bg-opacity-10",
        RequestStatus.Rejected => "bg-danger bg-opacity-10",
        RequestStatus.Failed => "bg-danger bg-opacity-10",
        _ => "bg-light"
    };

    private string GetStatusBadgeClass(RequestStatus status) => UiHelper.GetStatusBadgeClass(status);
}
