@* Unified summary card for workflow approval - combines context, progress, and step info *@
@using Requestr.Core.Models
@inject IUserTimezoneService Tz

<div class="card mb-4">
    <div class="card-body">
        <!-- Header: Form name and badges -->
        <div class="d-flex align-items-start justify-content-between mb-3">
            <div>
                <h4 class="mb-2">@FormName</h4>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge @GetRequestTypeBadgeClass()">
                        @GetRequestTypeLabel()
                    </span>
                    <span class="badge @GetStatusBadgeClass()">
                        @Status
                    </span>
                    @if (!string.IsNullOrEmpty(TableName))
                    {
                        <span class="text-muted small">
                            <i class="bi bi-table me-1"></i>@TableName
                        </span>
                    }
                    @if (RecordCount > 1)
                    {
                        <span class="badge bg-secondary">
                            @RecordCount records
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- Metadata footer -->
        <div class="d-flex justify-content-between align-items-center text-muted small border-top pt-3">
            <div>
                <span>
                    <i class="bi bi-person me-1"></i>
                    Requested by @RequestedByName
                </span>
                <span class="ms-3">
                    <i class="bi bi-clock me-1"></i>
                    @Tz.FormatDateTime(RequestedAt)
                </span>
            </div>
            @if (!string.IsNullOrEmpty(RequestLink))
            {
                <a href="@RequestLink" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-box-arrow-up-right me-1"></i>View Request
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string FormName { get; set; } = string.Empty;
    [Parameter] public string? TableName { get; set; }
    [Parameter] public RequestType RequestType { get; set; }
    [Parameter] public RequestStatus Status { get; set; }
    [Parameter] public int RecordCount { get; set; } = 1;
    [Parameter] public int CurrentStep { get; set; }
    [Parameter] public int TotalSteps { get; set; }
    [Parameter] public string? StepDescription { get; set; }
    [Parameter] public string RequestedByName { get; set; } = string.Empty;
    [Parameter] public DateTime RequestedAt { get; set; }
    [Parameter] public string? RequestLink { get; set; }

    private string GetRequestTypeLabel() => RequestType switch
    {
        RequestType.Insert => "Insert",
        RequestType.Update => "Update",
        RequestType.Delete => "Delete",
        _ => "Request"
    };

    private string GetRequestTypeBadgeClass() => UiHelper.GetRequestTypeBadgeClass(RequestType);
    private string GetStatusBadgeClass() => UiHelper.GetStatusBadgeClass(Status);
}
