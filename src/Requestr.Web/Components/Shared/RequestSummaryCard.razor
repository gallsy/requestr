@* Unified summary card for individual requests - combines context, status, and metadata *@
@using Requestr.Core.Models
@inject IUserTimezoneService Tz

<div class="request-summary-card card mb-4">
    <div class="card-body">
        <!-- Header with form name and badges -->
        <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex align-items-center gap-3">
                <div class="request-type-icon @GetRequestTypeClass()">
                    <i class="bi @GetRequestTypeIcon()"></i>
                </div>
                <div>
                    <h5 class="card-title mb-1">@FormName</h5>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (!string.IsNullOrEmpty(TableName))
                        {
                            <small class="text-muted">
                                <i class="bi bi-table me-1"></i>@TableName
                            </small>
                        }
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge @GetRequestTypeBadgeClass() fs-6">
                    @GetRequestTypeLabel()
                </span>
                <span class="badge @GetStatusBadgeClass() fs-6">
                    @Status
                </span>
            </div>
        </div>

        <!-- Status explainer message -->
        <div class="status-message mt-3 p-3 rounded @GetStatusBackgroundClass()">
            <div class="d-flex align-items-start gap-2">
                <i class="bi @GetStatusIcon() @GetStatusIconColor()"></i>
                <div>
                    <strong class="d-block">@GetStatusTitle()</strong>
                    <span class="text-muted">@GetStatusMessage()</span>
                </div>
            </div>
        </div>

        <!-- Comments section (if provided) -->
        @if (!string.IsNullOrEmpty(Comments))
        {
            <div class="mt-3 pt-3 border-top">
                <div class="d-flex align-items-start gap-2">
                    <i class="bi bi-chat-left-text text-muted"></i>
                    <div>@Comments</div>
                </div>
            </div>
        }

        <!-- Rejection reason (if applicable) -->
        @if (!string.IsNullOrEmpty(RejectionReason))
        {
            <div class="mt-3 p-3 bg-danger bg-opacity-10 border border-danger rounded">
                <div class="d-flex align-items-start gap-2">
                    <i class="bi bi-x-circle text-danger"></i>
                    <div>
                        <strong class="d-block text-danger">Rejection Reason</strong>
                        @RejectionReason
                    </div>
                </div>
            </div>
        }

        <!-- Failure message (if application to database failed) -->
        @if (!string.IsNullOrEmpty(FailureMessage))
        {
            <div class="mt-3 p-3 bg-danger bg-opacity-10 border border-danger rounded">
                <div class="d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-triangle text-danger"></i>
                    <div>
                        <strong class="d-block text-danger">Error Details</strong>
                        <span class="text-break">@FailureMessage</span>
                    </div>
                </div>
            </div>
        }

        <!-- Metadata footer -->
        <div class="mt-3 pt-3 border-top small">
            <div class="d-flex flex-wrap gap-3">
                @if (!string.IsNullOrEmpty(SubmittedBy))
                {
                    <span class="text-muted">
                        <i class="bi bi-person me-1"></i>@SubmittedBy
                    </span>
                }
                @if (SubmittedAt.HasValue)
                {
                    <span class="text-muted">
                        <i class="bi bi-calendar me-1"></i>@Tz.FormatDateTime(SubmittedAt.Value)
                    </span>
                }
            </div>
            @if (!string.IsNullOrEmpty(ProcessedBy))
            {
                <div class="mt-2">
                    <span class="text-muted">
                        <i class="bi bi-check-circle me-1"></i>Processed by @ProcessedBy
                        @if (ProcessedAt.HasValue)
                        {
                            <span> on @Tz.FormatDateTime(ProcessedAt.Value)</span>
                        }
                    </span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string FormName { get; set; } = string.Empty;
    [Parameter] public string? TableName { get; set; }
    [Parameter] public RequestType RequestType { get; set; }
    [Parameter] public RequestStatus Status { get; set; }
    [Parameter] public string? Comments { get; set; }
    [Parameter] public string? RejectionReason { get; set; }
    [Parameter] public string? FailureMessage { get; set; }
    [Parameter] public string? SubmittedBy { get; set; }
    [Parameter] public DateTime? SubmittedAt { get; set; }
    [Parameter] public string? ProcessedBy { get; set; }
    [Parameter] public DateTime? ProcessedAt { get; set; }
    [Parameter] public bool HasWorkflow { get; set; }

    private string GetRequestTypeIcon() => UiHelper.GetRequestTypeIcon(RequestType);
    private string GetRequestTypeClass() => UiHelper.GetRequestTypeClass(RequestType);
    private string GetRequestTypeBadgeClass() => UiHelper.GetRequestTypeBadgeClass(RequestType);
    private string GetRequestTypeLabel() => UiHelper.GetRequestTypeLabel(RequestType);
    private string GetStatusBadgeClass() => UiHelper.GetStatusBadgeClass(Status);
    private string GetStatusIcon() => UiHelper.GetStatusIcon(Status);
    private string GetStatusIconColor() => UiHelper.GetStatusIconColor(Status);
    private string GetStatusBackgroundClass() => UiHelper.GetStatusBackgroundClass(Status);
    private string GetStatusTitle() => UiHelper.GetStatusTitle(Status, HasWorkflow);
    private string GetStatusMessage() => UiHelper.GetStatusMessage(Status, HasWorkflow);
}

<style>
    .request-summary-card .request-type-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .request-type-insert {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
    }

    .request-type-update {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .request-type-delete {
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
    }

    .request-type-default {
        background: rgba(107, 114, 128, 0.15);
        color: #6b7280;
    }
</style>
